# ============================================================
# Maverick MCP (TradingView / daytrade) - variáveis de ambiente
# Copie para .env e preencha. NÃO faça commit do .env.
# ============================================================

# Caminho ABSOLUTO para o repositório clonado do maverick-mcp
# (ex.: /home/voce/code/maverick-mcp)
MAVERICK_MCP_DIR=/path/to/maverick-mcp

# OBRIGATÓRIO - provedor de dados de mercado (free tier em https://tiingo.com)
TIINGO_API_KEY=

# ---- Opcionais (recursos avançados) ----
# OPENROUTER_API_KEY=   # acesso a 400+ modelos de IA
# EXA_API_KEY=          # busca na web
# FRED_API_KEY=         # dados econômicos do Federal Reserve
# TAVILY_API_KEY=       # busca alternativa
# ADANOS_API_KEY=       # sentimento (Reddit, X, News, Polymarket)
