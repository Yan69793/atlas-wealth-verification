# ============================================================
# Maverick MCP (TradingView / daytrade) - variáveis de ambiente
# Copie para .env e preencha. NÃO faça commit do .env.
# ============================================================

# Caminho ABSOLUTO para o repositório clonado do maverick-mcp
# (ex.: /home/voce/code/maverick-mcp)
MAVERICK_MCP_DIR=/path/to/maverick-mcp

# OBRIGATÓRIO - provedor de dados de mercado (free tier em https://tiingo.com)
TIINGO_API_KEY=

# ---- Opcionais (recursos avançados do maverick-mcp) ----
# OPENROUTER_API_KEY=   # acesso a 400+ modelos de IA
# EXA_API_KEY=          # busca na web
# FRED_API_KEY=         # dados econômicos do Federal Reserve
# TAVILY_API_KEY=       # busca alternativa
# ADANOS_API_KEY=       # sentimento (Reddit, X, News, Polymarket)

# ============================================================
# TradingView Desktop bridge (tradesdontlie/tradingview-mcp)
# ============================================================
# Caminho ABSOLUTO para o repositório clonado do tradingview-mcp
TRADINGVIEW_MCP_DIR=/path/to/tradingview-mcp
# Não usa variáveis de ambiente; conecta no TradingView Desktop local
# via Chrome DevTools Protocol (porta 9222, habilitada no launch).

# ============================================================
# Bybit (execução de ordens) - bybit-exchange/trading-mcp
# Crie chaves SEM permissão de saque. Comece com BYBIT_TESTNET=true.
# ============================================================
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Alternativa a SECRET: caminho para PEM RSA
# BYBIT_API_PRIVATE_KEY_PATH=/absolute/path/to/bybit_private.pem
